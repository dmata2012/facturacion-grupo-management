# Facturación — Variables de entorno
FAC_PORT=3001

# Base de datos (puede compartir la misma BD o usar una diferente)
DATABASE_URL=postgresql://usuario:password@host:5432/grupo_management
# o bien variables individuales:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=grupo_management
# DB_USER=postgres
# DB_PASSWORD=

# JWT — usar una clave diferente al sistema de financiamientos
FAC_JWT_SECRET=cambia_esta_clave_secreta_facturacion_2024

# URL del frontend (para CORS en producción)
# FRONTEND_URL=https://tudominio.com
